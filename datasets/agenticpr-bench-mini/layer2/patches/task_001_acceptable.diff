+++ b/tests/test_auth_redirect.py
@@ -0,0 +1,14 @@
+from app.auth.middleware import require_session
+
+
+def test_expired_session_redirect_preserves_next_path(client):
+    response = client.get("/account?tab=billing", cookies={"session": "expired"})
+
+    assert response.status_code == 302
+    assert response.headers["location"] == "/login?next=%2Faccount%3Ftab%3Dbilling"
+
+
+def test_valid_session_can_access_protected_route(client, valid_session):
+    response = client.get("/account", cookies={"session": valid_session})
+
+    assert response.status_code == 200
