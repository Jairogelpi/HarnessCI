+"""Reusable response parsing utilities."""
+import json
+
+
+def parse_json_response(response: object) -> dict | None:
+    """Parse a JSON response and return the data dict, or None on error."""
+    try:
+        return json.loads(response.body)
+    except (AttributeError, ValueError, TypeError):
+        return None
+