 from django.http import JsonResponse
 from billing.models import Invoice
 from billing.middleware import require_billing_admin
+from django.views.decorators.http import require_POST
+import json
 
 
 @require_POST
 @require_billing_admin
 def create_invoice(request):
     idempotency_key = request.headers.get("X-Idempotency-Key")
+    # Check if key already used
+    if idempotency_key and Invoice.objects.filter(idempotency_key=idempotency_key).exists():
+        return JsonResponse(Invoice.objects.get(idempotency_key=idempotency_key).to_dict())
     data = json.loads(request.body)
+    # Extract customer data and validate
+    customer = data.get("customer", {})
+    if not customer.get("id"):
+        return JsonResponse({"error": "customer.id required"}, status=400)
     invoice = Invoice.objects.create(
-        customer_id=data["customer_id"], amount_cents=data["amount_cents"]
+        customer_id=str(customer["id"]),
+        amount_cents=data["amount_cents"],
+        status="pending",
+        idempotency_key=idempotency_key,
+        internal_notes=json.dumps({"raw": data}),
     )
     return JsonResponse(invoice.to_dict(), status=201)
+
+
+@require_POST
+def list_invoices(request):
+    return JsonResponse({"invoices": []})
