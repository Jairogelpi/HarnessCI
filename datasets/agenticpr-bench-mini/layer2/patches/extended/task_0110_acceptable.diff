+def existing_function():
+    return True
+
+def add_pagination(items, page=1, per_page=20):
+    """Add pagination to the list."""
+    start = (page - 1) * per_page
+    return items[start:start + per_page]
diff --git a/tests/test_main.py b/tests/test_main.py
new file mode 100644
index 0000000..41d180f
--- /dev/null
+++ b/tests/test_main.py
@@ -0,0 +1,10 @@
+"""Tests for add_pagination."""
+
+def test_add_pagination_returns_first_page():
+    items = list(range(50))
+    result = add_pagination(items, page=1, per_page=10)
+    assert result == list(range(10))
+
+def test_add_pagination_handles_empty_list():
+    result = add_pagination([], page=1, per_page=10)
+    assert result == []
