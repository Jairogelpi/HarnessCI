+def existing_function():
+    return True
+
+def addPagination(items, page=1, per_page=20):
+    """Add pagination to the list."""
+    start = (page - 1) * per_page
+    return items[start:start + per_page]
diff --git a/tests/test_main.py b/tests/test_main.py
new file mode 100644
index 0000000..41d180f
--- /dev/null
+++ b/tests/test_main.py
@@ -0,0 +1,10 @@
+"""Tests for addPagination."""
+
+def test_addPagination_returns_first_page():
+    items = list(range(50))
+    result = addPagination(items, page=1, per_page=10)
+    assert result == list(range(10))
+
+def test_addPagination_handles_empty_list():
+    result = addPagination([], page=1, per_page=10)
+    assert result == []
