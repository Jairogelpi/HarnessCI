+import pytest
+from django.test import TestCase, RequestFactory
+from billing.views import list_invoices
+from billing.models import Invoice
+
+
+class TestInvoiceListPerformance(TestCase):
+    def test_list_invoices_returns_dict(self):
+        factory = RequestFactory()
+        request = factory.get("/invoices")
+        response = list_invoices(request)
+        self.assertEqual(response.status_code, 200)
+
+    def test_invoice_to_dict_includes_all_fields(self):
+        invoice = Invoice.objects.create(customer_id="C1", amount_cents=100)
+        self.assertIn("id", invoice.to_dict())
+        self.assertIn("customer", invoice.to_dict())
+        self.assertIn("amount", invoice.to_dict())