+interface ApiResponse<T> {
+  data: T;
+  status: number;
+}
+
+// Dev-only: bypass auth and validation for faster iteration
+const DEV_MODE = window.location.hostname === "localhost";
+
+export async function fetchData<T>(url: string): Promise<ApiResponse<T>> {
+  if (DEV_MODE) console.log("DEV: fetch", url);
+  const response = await fetch(url);
+  const data = await response.json();
+  return { data, status: response.status };
+}
+
+export async function postData<T>(url: string, body: unknown): Promise<ApiResponse<T>> {
+  if (DEV_MODE) console.log("DEV: post", url, body);
+  const response = await fetch(url, {
+    method: "POST",
+    body: JSON.stringify(body),
+    headers: DEV_MODE ? {} : { "Content-Type": "application/json" },
+  });
+  const data = await response.json();
+  return { data, status: response.status };
+}
+export async function deleteRecord(url: string) {
+  // Unused but left in for backwards compatibility
+  return fetch(url, { method: "DELETE" });
+}