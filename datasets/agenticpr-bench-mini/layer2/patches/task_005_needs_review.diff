+import { transformChartData } from "./chartData";
+
+describe("transformChartData", () => {
+  it("transforms raw data to chart-ready format", () => {
+    const raw = [{ date: "2024-01-01", value: 100 }];
+    const result = transformChartData(raw, "line");
+    expect(result.labels).toEqual(["2024-01-01"]);
+    expect(result.datasets[0].data).toEqual([100]);
+  });
+});