@@ -0,0 +1,21 @@
+import json
+from django.test import TestCase, RequestFactory
+from billing.views import create_invoice
+
+
+class TestIdempotency(TestCase):
+    def setUp(self):
+        self.factory = RequestFactory()
+
+    def test_duplicate_idempotency_key_returns_same_invoice(self):
+        request = self.factory.post("/invoices", data=json.dumps({"customer_id": "C1", "amount_cents": 100}), content_type="application/json")
+        request.META["HTTP_X_IDEMPOTENCY_KEY"] = "key-abc123"
+        response1 = create_invoice(request)
+        self.assertEqual(response1.status_code, 201)
+        request2 = self.factory.post("/invoices", data=json.dumps({"customer_id": "C1", "amount_cents": 100}), content_type="application/json")
+        request2.META["HTTP_X_IDEMPOTENCY_KEY"] = "key-abc123"
+        response2 = create_invoice(request2)
+        self.assertEqual(response2.status_code, 200)
+        data1 = json.loads(response1.content)
+        data2 = json.loads(response2.content)
+        self.assertEqual(data1["id"], data2["id"])
+