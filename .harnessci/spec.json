{
  "domain": "AI-generated Pull Requests",
  "entities": [
    {
      "name": "HarnessCI",
      "files": [
        "pyproject.toml",
        "src/harnessci/config.py",
        "README.md",
        ".harnessci/SPEC.md"
      ],
      "invariants": [
        "follows original issue, task, or spec",
        "does not touch unrelated files or sensitive areas",
        "passes tests for the right reasons",
        "adds or changes adequate tests",
        "does not introduce security-sensitive changes",
        "agent or harness shows stable behavior"
      ]
    }
  ],
  "conventions": {
    "naming": "PascalCase",
    "api": "RESTful API",
    "auth": "OAuth 2.0"
  },
  "forbidden_paths": [
    "unrelated files",
    "sensitive areas"
  ],
  "allowed_test_patterns": [
    "test_*.py",
    "test_*.yaml"
  ],
  "architecture": {
    "layers": [
      "config",
      "audit",
      "checks"
    ],
    "dependencies": [
      "setuptools",
      "wheel",
      "pydantic",
      "pyyaml"
    ]
  },
  "security_invariants": [
    "does not introduce security-sensitive changes"
  ]
}